# Base de datos PostgreSQL (Prisma 7 lee DATABASE_URL vía prisma.config.ts)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/registros?schema=public"

# Auth.js — genera un secreto: `npx auth secret` o openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → APIs y servicios → Credenciales)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Correo (Gmail: contraseña de aplicación). Requerido para enviar notificaciones.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=
# Opcional: remitente distinto del usuario SMTP
# SMTP_FROM="Registros <tu_cuenta@gmail.com>"

# URL pública de la app (enlaces en correos). En Vercel suele inferirse.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Acceso a paneles
# Si OFFICER_EMAILS está vacío, cualquier usuario con Google login entra a /visitas
OFFICER_EMAILS=
# ADMIN_EMAILS es obligatorio para /admin
ADMIN_EMAILS=

# Opcional: integración Gmail / Drive (más adelante)
# GOOGLE_DRIVE_FOLDER_ID=

# Google Drive/Sheets (recomendado: Service Account)
# Crear una service account en Google Cloud → IAM & Admin → Service Accounts
# Luego en ese service account: generar/descargar la private key.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Drive/Sheets destino
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_NAME=Registros
GOOGLE_SHEETS_SPREADSHEET_ID=
# Si NO se proporciona el ID, se creará una spreadsheet por este título (y se reutilizarán IDs guardados en BD)
GOOGLE_SHEETS_SPREADSHEET_TITLE=Registros
# Nombre de la hoja dentro del spreadsheet (por defecto "Hoja 1")
GOOGLE_SHEETS_SHEET_NAME=Hoja 1
