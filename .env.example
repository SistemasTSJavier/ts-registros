# --- Base de datos: Supabase (PostgreSQL) ---
# 1) https://supabase.com → New project → espera a que esté "Healthy" (si está pausado, reactívalo).
#
# 2) Project Settings → Database → Connection string:
#    - Si da error de conexión (por IPv6 o pooler) en Windows/red doméstica,
#      suele ser IPv6: usa la URI de **Session pooler** o **Transaction pooler** (puerto 6543),
#      no la conexión "Direct" a db.xxx.supabase.co:5432.
#    - Copia la cadena que muestre Supabase (URI) y sustituye la contraseña.
#    - Añade si falta: ?sslmode=require
#
# 3) Prueba conectividad (PowerShell): Test-NetConnection db.TU_REF.supabase.co -Port 5432
#
# 4) Crea/asegura las tablas en Supabase (workspace, user_workspace, google_integration_state,
#    sheet_token_lookup para enlaces de aprobación sin sesión). Ejemplo:
#    CREATE TABLE IF NOT EXISTS public.sheet_token_lookup (
#      token_or_id TEXT PRIMARY KEY,
#      sheets_spreadsheet_id TEXT NOT NULL,
#      sheets_sheet_name TEXT NOT NULL
#    );
#
# En Vercel: misma DATABASE_URL en Environment Variables.
DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.TU_REF.supabase.co:5432/postgres?sslmode=require"

# Auth.js — genera un secreto: `npx auth secret` o openssl rand -base64 32
AUTH_SECRET=
# Alias compatible (Vercel / tutoriales antiguos):
# NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3000
# Alias compatible:
# NEXTAUTH_URL=http://localhost:3000
# En Vercel suele hacer falta:
# AUTH_TRUST_HOST=true
#
# === Checklist Vercel (producción) ===
# Copia TODAS las variables que uses en local, con estos matices:
# - AUTH_URL = https://TU-DOMINIO.vercel.app   (NO dejes http://localhost)
# - AUTH_SECRET = obligatorio; debe ser FIJO entre deploys (si lo cambias, todos deben volver a iniciar sesión)
# - AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET = mismo cliente OAuth que en Google Cloud (origen + redirect de producción)
# - DATABASE_URL, GOOGLE_SERVICE_ACCOUNT_*, etc. = mismos conceptos que en local
# Los logs del servidor (p. ej. errores al enviar correo) están en: Vercel → proyecto → Logs → filtro por función,
# o Runtime Logs al enviar el formulario; en el navegador solo verás el mensaje que devuelve la Server Action.

# Google OAuth (Google Cloud Console → APIs y servicios → Credenciales)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Alias compatible:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Correo (notificaciones a los del formulario) ---
# Opción A (recomendada en Vercel): SMTP con una cuenta dedicada (p. ej. Gmail + «contraseña de aplicación»).
# Si SMTP_HOST, SMTP_USER y SMTP_PASS están definidos, la app usa SOLO esto y no depende del OAuth Gmail del usuario.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_buzon@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Opcional: remitente mostrado (si no, se usa «Registros <SMTP_USER>»)
# SMTP_FROM="Registros visitas <tu_buzon@gmail.com>"
#
# Opción B: sin SMTP, se usa Gmail API con la cuenta con la que el usuario inició sesión (scope gmail.send + Gmail API habilitada).
# Si falla, configura la opción A.

# URL pública de la app (enlaces en correos). En Vercel suele inferirse.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Acceso a paneles
# Si OFFICER_EMAILS está vacío, cualquier usuario con Google login entra a /visitas
# Varios oficiales (p. ej. 10 correos separados por coma) comparten el MISMO panel y los MISMOS datos en Sheets/Drive.
# No se crea una carpeta por cada usuario que inicia sesión: hay una sola integración Google para la organización.
OFFICER_EMAILS=
# ADMIN_EMAILS es obligatorio para /admin
ADMIN_EMAILS=

# --- Modelo: una instalación = un sistema aislado (sin enlazar con otras apps o proyectos) ---
# Cada despliegue (p. ej. un proyecto Vercel + su DATABASE_URL + sus variables) es independiente.
# La "cuenta maestra" técnica es la CUENTA DE SERVICIO: con ella la app crea UNA carpeta y UNA hoja (o usas IDs fijos en env).
# Los oficiales humanos NO son dueños del Drive en el código: entran con Google (AUTH_GOOGLE_*) y listas OFFICER_EMAILS;
# si quieres que otros vean/editen la carpeta en Drive, comparte esa carpeta/hoja con sus Gmail o con el correo …@….iam.gserviceaccount.com.
# Otro cliente u otra sede = otro despliegue y otras credenciales Google/BD, sin mezclar servicios.

# --- Google Drive + Sheets (OBLIGATORIO para registros / programadas / JSON en Drive) ---
# NO es lo mismo que AUTH_GOOGLE_* (eso solo sirve para que los usuarios inicien sesión).
# Aquí hace falta una CUENTA DE SERVICIO + APIs en Google Cloud:
# 1) Mismo proyecto (o otro) → APIs y servicios → Habilitar "Google Drive API" y "Google Sheets API".
# 2) IAM y administración → Cuentas de servicio → Crear → Claves → JSON.
# 3) Copiar del JSON: "client_email" → GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL
#    y "private_key" → GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY (valor completo con -----BEGIN…----- / -----END…-----).
#    En Vercel: sin comillas rodeando el valor; si OpenSSL dice "DECODER routines::unsupported",
#    suele ser PEM mal pegado: vuelve a pegar desde el JSON o pon \n como saltos de línea reales.
#
# Los archivos se crean en el Drive de la cuenta de servicio (no en tu Gmail).
# Para usar TU carpeta/hoja: comparte AMBOS con el correo …@….iam.gserviceaccount.com como Editor.
# Si ves "The caller does not have permission", suele ser carpeta/hoja no compartida o ID mal copiado.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_NAME=Registros
GOOGLE_SHEETS_SPREADSHEET_ID=
# Necesario para evitar crear en Drive 'root' (que suele fallar por permisos).
# Crea una carpeta EXCLUSIVA para este servicio y pon su ID aquí (compártela con la cuenta de servicio).
# Si mantienes IDs fijos, puedes también setear GOOGLE_SHEETS_SPREADSHEET_ID.
GOOGLE_SHEETS_SPREADSHEET_TITLE=Registros
GOOGLE_SHEETS_SHEET_NAME=Hoja 1
