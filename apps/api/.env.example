PORT=3001

# Supabase PostgreSQL — en Vercel usa Session pooler (puerto 6543), no conexión directa 5432
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase project (Settings → API)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT signing secret (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Registros <onboarding@resend.dev>

# Public app URL for links in emails
APP_URL=http://localhost:5173

# Optional: protect /api/email/* from direct browser calls
EMAIL_API_SECRET=

# Initial admin (created on first boot or after db:reset)
ADMIN_EMAIL=admin@registros.app
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Administrador
