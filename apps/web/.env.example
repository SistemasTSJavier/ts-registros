# Set to false to use the Hono API (local :3001 or Vercel /api)
VITE_USE_MOCK=false

# Leave empty for same-origin /api (Vercel and local Vite proxy)
VITE_API_URL=

# URL pública de la app (enlaces en correos)
VITE_APP_URL=http://localhost:5173

# Activar envío real con Resend (requiere API backend)
VITE_EMAIL_ENABLED=false

VITE_EMAIL_API_SECRET=
